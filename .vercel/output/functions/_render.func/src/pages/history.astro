---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';
---

<Layout title="Reading History">
  <main class="history">
    <header class="history-header">
      <a href="/" class="back-btn" aria-label="Back to library">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <h1 class="history-title">Reading History</h1>
    </header>
    <div class="history-list" id="history-list">
      <!-- Populated by JS -->
    </div>
    <div class="empty-state" id="empty-state" style="display: none;">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 19.5C4 18.837 4.26339 18.2011 4.73223 17.7322C5.20107 17.2634 5.83696 17 6.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M6.5 2H20V22H6.5C5.83696 22 5.20107 21.7366 4.73223 21.2678C4.26339 20.7989 4 20.163 4 19.5V4.5C4 3.83696 4.26339 3.20107 4.73223 2.73223C5.20107 2.26339 5.83696 2 6.5 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="empty-title">No reading history yet</span>
      <span class="empty-subtitle">Start reading from your <a href="/">library</a></span>
    </div>
  </main>
  <BottomNav />
</Layout>

<script>
  import { initTheme } from '../scripts/theme';
  import { getAllProgress } from '../scripts/storage';

  initTheme();

  interface NovelCatalogItem {
    id: string;
    title: string;
    slug: string;
    cover: string;
    totalChapters: number;
  }

  interface NovelProgress {
    lastChapter: number;
    lastReadAt: string;
  }

  interface HistoryItem extends NovelCatalogItem {
    progress: NovelProgress;
  }

  function getRelativeTime(dateString: string): string {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return `${diffMins}m ago`;
    if (diffHours < 24) return `${diffHours}h ago`;
    if (diffDays < 7) return `${diffDays}d ago`;
    if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
    if (diffDays < 365) return `${Math.floor(diffDays / 30)}mo ago`;
    return `${Math.floor(diffDays / 365)}y ago`;
  }

  async function loadHistory(): Promise<void> {
    const progress = getAllProgress();
    const res = await fetch('/novels/index.json');
    const data: { novels: NovelCatalogItem[] } = await res.json();
    
    // Filter novels that have progress, sort by lastReadAt descending
    const historyItems: HistoryItem[] = data.novels
      .filter(novel => progress[novel.slug])
      .map(novel => ({
        ...novel,
        progress: progress[novel.slug]
      }))
      .sort((a, b) => new Date(b.progress.lastReadAt).getTime() - new Date(a.progress.lastReadAt).getTime());

    const list = document.getElementById('history-list');
    const empty = document.getElementById('empty-state');
    if (!list || !empty) return;

    if (historyItems.length === 0) {
      list.style.display = 'none';
      empty.style.display = 'flex';
      return;
    }

    list.innerHTML = historyItems.map((item, index) => {
      const progressPercent = Math.round((item.progress.lastChapter / item.totalChapters) * 100);
      const relativeTime = getRelativeTime(item.progress.lastReadAt);
      
      return `
        <a href="/novel/${item.slug}" class="history-item" style="animation-delay: ${index * 40}ms">
          <img src="${item.cover}" alt="${item.title}" class="history-cover" loading="lazy" />
          <div class="history-info">
            <span class="history-title">${item.title}</span>
            <span class="history-chapter">Chapter ${item.progress.lastChapter} of ${item.totalChapters}</span>
            <div class="progress-bar-container">
              <div class="progress-bar">
                <div class="progress-fill" style="width: ${progressPercent}%"></div>
              </div>
            </div>
            <span class="history-date">${relativeTime}</span>
          </div>
          <svg class="chevron-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      `;
    }).join('');
  }

  loadHistory();
</script>

<style>
  /* === Keyframes === */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* === Layout === */
  .history {
    padding: var(--space-md);
    padding-top: calc(var(--safe-top) + var(--space-md));
    padding-bottom: calc(var(--bottom-nav-height) + var(--space-md) + var(--safe-bottom));
    min-height: 100dvh;
  }

  /* === Header (static elements - scoped is fine) === */
  .history-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .back-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }

  .back-btn:hover {
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .back-btn:active {
    transform: scale(0.95);
  }

  .history-header .history-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  /* === History List === */
  .history-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* === Dynamic content: use :global() since innerHTML doesn't get scoped attrs === */
  .history-list :global(.history-item) {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-normal);
    opacity: 0;
    animation: fadeInUp 0.4s ease forwards;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid var(--color-border);
  }

  :global([data-theme="dark"]) .history-list :global(.history-item) {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
  }

  .history-list :global(.history-item:last-child) {
    border-bottom: none;
  }

  .history-list :global(.history-item:hover) {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    border-color: var(--color-accent);
  }

  :global([data-theme="dark"]) .history-list :global(.history-item:hover) {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .history-list :global(.history-item:active) {
    transform: scale(0.98);
  }

  /* === Cover === */
  .history-list :global(.history-cover) {
    width: 64px;
    height: 85px;
    object-fit: cover;
    border-radius: var(--radius-md);
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  :global([data-theme="dark"]) .history-list :global(.history-cover) {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  /* === Info === */
  .history-list :global(.history-info) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .history-list :global(.history-title) {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--color-text);
  }

  .history-list :global(.history-chapter) {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  /* === Progress Bar === */
  .history-list :global(.progress-bar-container) {
    margin-top: 2px;
  }

  .history-list :global(.progress-bar) {
    width: 100%;
    height: 3px;
    background: rgba(0, 0, 0, 0.1);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  :global([data-theme="dark"]) .history-list :global(.progress-bar) {
    background: rgba(255, 255, 255, 0.1);
  }

  .history-list :global(.progress-fill) {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent), #a78bfa);
    border-radius: var(--radius-full);
    transition: width var(--transition-normal);
    box-shadow: 0 0 8px rgba(96, 165, 250, 0.5);
  }

  .history-list :global(.history-date) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  /* === Chevron Icon === */
  .history-list :global(.chevron-icon) {
    flex-shrink: 0;
    color: var(--color-text-muted);
    opacity: 0.5;
    transition: all var(--transition-fast);
  }

  .history-list :global(.history-item:hover .chevron-icon) {
    opacity: 1;
    transform: translateX(2px);
  }

  /* === Empty State === */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-2xl);
    text-align: center;
    min-height: 50vh;
  }

  .empty-state svg {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .empty-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .empty-subtitle {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .empty-subtitle a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .empty-subtitle a:hover {
    text-decoration: none;
  }

  /* === Responsive === */
  @media (min-width: 640px) {
    .history-list {
      max-width: 600px;
      margin: 0 auto;
    }
  }
</style>
