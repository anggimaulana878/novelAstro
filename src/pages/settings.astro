---
import Layout from '../layouts/Layout.astro';
import BottomNav from '../components/BottomNav.astro';

export const prerender = true;
---

<Layout title="Settings" canonicalPath="/settings">
  <div class="settings-page">
    <header class="page-header">
      <h1>Settings</h1>
    </header>

    <main class="settings-content">
      <!-- Theme -->
      <section class="setting-group">
        <h2 class="setting-label">Theme</h2>
        <div class="setting-options" id="theme-options">
          <button class="option-btn touch-target" data-value="light" aria-label="Light theme">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <span>Light</span>
          </button>
          <button class="option-btn touch-target" data-value="dark" aria-label="Dark theme">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <span>Dark</span>
          </button>
          <button class="option-btn touch-target" data-value="system" aria-label="System theme">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <span>Auto</span>
          </button>
        </div>
      </section>

      <!-- Font Size -->
      <section class="setting-group">
        <h2 class="setting-label">Font Size</h2>
        <div class="font-size-control">
          <span class="size-label size-small">A</span>
          <input type="range" id="font-size-slider" min="1" max="5" step="1" value="3" class="slider" aria-label="Font size">
          <span class="size-label size-large">A</span>
        </div>
        <p class="preview-text" id="font-preview">The quick brown fox jumps over the lazy dog.</p>
      </section>

      <!-- Font Family -->
      <section class="setting-group">
        <h2 class="setting-label">Font</h2>
        <div class="setting-options" id="font-options">
          <button class="option-btn touch-target" data-value="sans" aria-label="Sans-serif font">
            <span style="font-family: sans-serif;">Aa</span>
            <span>Sans</span>
          </button>
          <button class="option-btn touch-target" data-value="serif" aria-label="Serif font">
            <span style="font-family: serif;">Aa</span>
            <span>Serif</span>
          </button>
          <button class="option-btn touch-target" data-value="mono" aria-label="Monospace font">
            <span style="font-family: monospace;">Aa</span>
            <span>Mono</span>
          </button>
        </div>
      </section>

      <!-- About -->
      <section class="setting-group">
        <h2 class="setting-label">About</h2>
        <p class="about-text">Novel Reader — a minimal web novel reader optimized for batch reading and Google Assistant "Read It" compatibility.</p>
      </section>
    </main>
  </div>

  <BottomNav active="settings" />
</Layout>

<script>
  import { initTheme, setTheme } from '../scripts/theme';
  import { getSettings, setSettings } from '../scripts/storage';

  initTheme();

  const themeOptions = document.getElementById('theme-options')!;
  const fontSizeSlider = document.getElementById('font-size-slider') as HTMLInputElement;
  const fontOptions = document.getElementById('font-options')!;

  function syncUI(): void {
    const settings = getSettings();

    themeOptions.querySelectorAll('.option-btn').forEach((btn) => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.value === settings.theme);
    });

    fontSizeSlider.value = String(settings.fontSize);

    fontOptions.querySelectorAll('.option-btn').forEach((btn) => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.value === settings.fontFamily);
    });
  }

  syncUI();

  // Theme
  themeOptions.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.option-btn') as HTMLElement | null;
    if (!btn) return;
    const value = btn.dataset.value as 'light' | 'dark' | 'system';
    setTheme(value);
    themeOptions.querySelectorAll('.option-btn').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
  });

  // Font size
  fontSizeSlider.addEventListener('input', () => {
    const size = parseInt(fontSizeSlider.value, 10) as 1 | 2 | 3 | 4 | 5;
    setSettings({ fontSize: size });
    document.documentElement.setAttribute('data-fontsize', String(size));
  });

  // Font family
  fontOptions.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.option-btn') as HTMLElement | null;
    if (!btn) return;
    const value = btn.dataset.value as 'serif' | 'sans' | 'mono';
    setSettings({ fontFamily: value });
    document.documentElement.setAttribute('data-font', value);
    fontOptions.querySelectorAll('.option-btn').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
  });
</script>

<style>
  .settings-page {
    padding: var(--space-md);
    padding-top: calc(var(--safe-top) + var(--space-md));
  }

  .page-header {
    margin-bottom: var(--space-xl);
  }

  .page-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .settings-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 480px;
  }

  .setting-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .setting-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .setting-options {
    display: flex;
    gap: var(--space-sm);
  }

  .option-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: var(--space-sm) var(--space-xs);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text-muted);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .option-btn.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .font-size-control {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .size-label {
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .size-small { font-size: 0.75rem; }
  .size-large { font-size: 1.25rem; }

  .slider {
    flex: 1;
    height: 4px;
    appearance: none;
    -webkit-appearance: none;
    background: var(--color-border);
    border-radius: var(--radius-full);
    outline: none;
  }

  .slider::-webkit-slider-thumb {
    appearance: none;
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-accent);
    cursor: pointer;
  }

  .slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-accent);
    border: none;
    cursor: pointer;
  }

  .preview-text {
    padding: var(--space-md);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    line-height: var(--line-height);
  }

  .about-text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
